# =============================================================================
# Data Contract Enforcer — LLM Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your chosen provider.
# Only ONE provider needs to be configured. The system auto-detects from
# available keys, or you can set LLM_PROVIDER explicitly.
#
# Supported providers: openai, anthropic, gemini, ollama, openrouter
# =============================================================================

# --- Option 1: Explicit provider selection (recommended) ---
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash
# LLM_API_KEY=your-api-key-here

# --- Option 2: Provider-specific keys (auto-detected) ---

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (uses OpenAI-compatible endpoint)
# GEMINI_API_KEY=AI...

# OpenRouter (access 100+ models via one key)
# OPENROUTER_API_KEY=sk-or-...

# --- Option 3: Local Ollama (no API key needed) ---
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Advanced: Custom OpenAI-compatible endpoint ---
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://your-custom-endpoint.com/v1
# LLM_API_KEY=your-key
# LLM_MODEL=your-model-name

# --- Embedding overrides (optional, defaults to chat provider) ---
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
